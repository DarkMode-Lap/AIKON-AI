GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEBUG=false

# DB
DATABASE_URL=sqlite+aiosqlite:///./aikon_ai.db

# Gemini 이미지 생성
GEMINI_IMAGE_MODEL=gemini-2.5-flash-preview-05-20
GEMINI_PROMPT_VERSION=v1
SPRING_CALLBACK_TOKEN=

# Feedback RAG
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=avatar_feedback_rag
RAG_TOP_K=3
RAG_MIN_SCORE=0.2

# S3 (MinIO 로컬: S3_ENDPOINT_URL=http://localhost:9000)
S3_BUCKET=aikon
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=your_aws_access_key_id
S3_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_REGION=ap-northeast-2
